{
  "name": "real-estate-data-agent",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "bash scripts/with-node24.sh eve dev",
    "start": "bash scripts/with-node24.sh eve start",
    "install:all": "pnpm install && pnpm --dir web install",
    "dev:web": "pnpm --dir web dev",
    "predev:all": "bash scripts/free-ports.sh && bash scripts/prepare-dev.sh",
    "dev:all": "bash scripts/with-node24.sh concurrently -n web,eve -c magenta,blue \"pnpm dev:web\" \"bash scripts/wait-web-then-eve.sh\"",
    "smoke": "node scripts/e2e-chat-smoke.mjs",
    "build:web": "pnpm --dir web build",
    "typecheck:web": "pnpm --dir web typecheck",
    "typecheck": "pnpm typecheck:web"
  },
  "dependencies": {
    "@ai-sdk/openai": "^4.0.4",
    "concurrently": "^9.1.0",
    "eve": "^0.12.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "just-bash": "^3.0.2",
    "typescript": "5.7.3"
  }
}
